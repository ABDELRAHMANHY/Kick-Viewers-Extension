{
  "manifest_version": 3,
  "name": "Kick Viewers & Chat",
  "version": "1.0",
  "description": "عداد مشاهدات ورسائل كيك",
  "browser_specific_settings": {
    "gecko": {
      "id": "kick-extension@abdulrahman.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {}
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.kick.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.kick.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["spy.js"],
      "matches": ["https://*.kick.com/*"]
    }
  ]
}